# =============================================================================
# Semantic Search System Configuration
# =============================================================================

# Embedding model (from sentence-transformers hub)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=data/chromadb

# Clustering
PCA_COMPONENTS=50
N_CLUSTERS=18

# Semantic cache
CACHE_SIMILARITY_THRESHOLD=0.60
CACHE_MAX_SIZE=10000

# API
API_HOST=0.0.0.0
API_PORT=8000
